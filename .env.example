# ================================================
# SHOPERY FRONTEND - ENVIRONMENT VARIABLES
# ================================================
# Скопируй файл в .env.local для локальной разработки
# 
# Пример:
#   cp .env.example .env.local
#   npm run dev  # Vite автоматічно загрузить переменные
#

# ==================== API ====================
# URL базовый для всех API запросов к бекенду
# Для локальной разработки: http://localhost:3000
# Для production: https://api.shopery.com
VITE_API_URL=http://localhost:3000

# ==================== DEMO MODE ====================
# Включить демо-режим (блокирует реальные действия)
# Используется для безопасного тестирования без риска испортить БД
# true = demo mode включен (товары с отрицательным ID, просмотр только)
# false = production mode
VITE_DEMO_MODE=false

# --- Demo User Credentials (чтение/просмотр) ---
VITE_DEMO_USER_EMAIL=demo@shopery.dev
VITE_DEMO_USER_PASSWORD=demo12345

# --- Demo Admin Credentials (управление товарами, но демо) ---
VITE_DEMO_ADMIN_EMAIL=admin@shopery.dev
VITE_DEMO_ADMIN_PASSWORD=admin12345

# ==================== STRIPE (опционально) ====================
# Публичный ключ Stripe (для обработки платежей)
# Получить на https://dashboard.stripe.com/
# 
# Формат: pk_test_... (development) или pk_live_... (production)
# VITE_STRIPE_PUBLIC_KEY=pk_test_51234567890abcdefg

# ==================== BUILD & RUNTIME ====================
# Окружение сборки (обычно автоматически)
# development = локальная разработка с отладкой
# production = optimized build для развертывания
# NODE_ENV=development
#
#
